# ----- Runtime -----
NODE_ENV=development
PORT=7002
CLIENT_ORIGIN=http://localhost:5173
# comma-separated allowlist; falls back to CLIENT_ORIGIN if unset
CORS_ALLOWLIST=http://localhost:5173

# ----- Database -----
MONGO_URI=mongodb+srv://user:pass@cluster/mern_task_manager

# ----- Auth / JWT -----
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
# Tokens: access 15m, refresh 7d (hard-coded in utils/token.js for now)

# ----- Redis (Upstash) -----
REDIS_URL=rediss://default:password@host:6379

# ----- Email (Nodemailer) -----
# Leave SMTP_USER blank to auto-use an Ethereal test account (preview URLs logged).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="MERN Task Manager <no-reply@example.com>"

# ----- Cloudinary (attachments) -----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ----- AI (DeepSeek) -----
# Get an API key at https://platform.deepseek.com.
# Leave DEEPSEEK_API_KEY blank to disable AI features (endpoints return fallback data).
DEEPSEEK_API_KEY=
# Available models: deepseek-chat (V3), deepseek-reasoner (R1)
AI_MODEL=deepseek-chat

# ----- Web Push (VAPID) -----
# Generate keys once with:  node -e "console.log(require('web-push').generateVAPIDKeys())"
# Leave blank to disable browser push notifications.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=

# ----- Slack notifications (optional) -----
# Create an Incoming Webhook at https://api.slack.com/messaging/webhooks
# Leave blank to disable Slack notifications.
SLACK_WEBHOOK_URL=

# ----- Public app URL (for links inside emails) -----
APP_URL=http://localhost:5173
